{{!< default}}

{{#post}}
<article class="page-full">
    <header class="page-hero">
        <div class="container page-hero-inner">
            <p class="section-eyebrow">{{#if primary_tag}}{{primary_tag.name}}{{else}}About Us{{/if}}</p>
            <h1 class="page-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="page-lead">{{custom_excerpt}}</p>
            {{/if}}
        </div>
    </header>

    {{#if feature_image}}
        {{#if @page.show_title_and_feature_image}}
        <figure class="post-full-image container">
            <img src="{{img_url feature_image size="xl"}}"
                 alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                 loading="lazy">
        </figure>
        {{/if}}
    {{/if}}

    <div class="page-content container-narrow">
        {{#if content}}
            {{content}}
        {{else}}
            <p class="empty-note">Content for this page will be added soon.</p>
        {{/if}}
    </div>
</article>
{{/post}}
