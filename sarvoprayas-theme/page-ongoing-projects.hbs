{{!< default}}

{{#post}}
<article class="page-full">
    <header class="page-hero">
        <div class="container page-hero-inner">
            <p class="section-eyebrow">Our Work</p>
            <h1 class="page-title">{{title}}</h1>
            {{#if custom_excerpt}}<p class="page-lead">{{custom_excerpt}}</p>{{else}}<p class="page-lead empty-note">Description will be added soon.</p>{{/if}}
        </div>
    </header>

    <section class="projects-section">
        <div class="container">

            {{!-- Optional intro content from Ghost editor --}}
            {{#if content}}
                <div class="page-content container-narrow" style="padding: 0 0 40px;">{{content}}</div>
            {{/if}}

            {{!-- Pulls posts tagged "ongoing-project" --}}
            {{#get "posts" filter="tag:ongoing-project" limit="100" include="tags" as |projects|}}
                {{#if projects}}
                    <div class="cards-grid" data-paginate="6">
                        {{#foreach projects}}
                            {{> "post-card"}}
                        {{/foreach}}
                    </div>
                {{else}}
                    <p class="empty-note">No ongoing projects to display at the moment. Please check back soon.</p>
                {{/if}}
            {{/get}}

        </div>
    </section>
</article>
{{/post}}
