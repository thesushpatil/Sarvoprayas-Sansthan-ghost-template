{{!< default}}

{{#post}}
<article class="page-full">
    <header class="page-hero">
        <div class="container page-hero-inner">
            <p class="section-eyebrow">Our Impact</p>
            <h1 class="page-title">{{title}}</h1>
            {{#if custom_excerpt}}<p class="page-lead">{{custom_excerpt}}</p>{{else}}<p class="page-lead empty-note">Description will be added soon.</p>{{/if}}
        </div>
    </header>

    <section class="projects-section">
        <div class="container">

            {{#if content}}
                <div class="page-content container-narrow" style="padding: 0 0 40px;">{{content}}</div>
            {{/if}}

            {{!-- Pulls posts tagged "past-project" — title-only cards (no images) --}}
            {{#get "posts" filter="tag:past-project" limit="100" include="tags" as |projects|}}
                {{#if projects}}
                    <div class="past-projects-grid" data-paginate="9">
                        {{#foreach projects}}
                            <a class="past-project-card" href="{{url}}">
                                <span class="past-project-name">{{title}}</span>
                                <span class="past-project-arrow" aria-hidden="true">&rarr;</span>
                            </a>
                        {{/foreach}}
                    </div>
                {{else}}
                    <p class="empty-note">No past projects to display at the moment. Please check back soon.</p>
                {{/if}}
            {{/get}}

        </div>
    </section>
</article>
{{/post}}
