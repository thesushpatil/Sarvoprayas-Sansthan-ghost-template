{{!< default}}

{{#post}}
<article class="page-full">
    <header class="page-hero">
        <div class="container page-hero-inner">
            <p class="section-eyebrow">Gallery</p>
            <h1 class="page-title">{{title}}</h1>
            {{#if custom_excerpt}}<p class="page-lead">{{custom_excerpt}}</p>{{else}}<p class="page-lead empty-note">Description will be added soon.</p>{{/if}}
        </div>
    </header>

    <section class="gallery-section">
        <div class="container">

            {{#if content}}
                <div class="page-content container-narrow" style="padding: 0 0 40px;">{{content}}</div>
            {{/if}}

            {{!-- If posts are tagged "gallery" in Ghost, show those; otherwise show the bundled photos below. --}}
            {{#get "posts" filter="tag:gallery" limit="100" as |gallery|}}
                {{#if gallery}}
                    <div class="gallery-grid" data-paginate="6">
                        {{#foreach gallery}}
                            <a class="gallery-item" href="{{url}}" aria-label="{{title}}">
                                {{#if feature_image}}
                                    <img src="{{img_url feature_image size="m"}}"
                                         alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                                         loading="lazy">
                                {{else}}
                                    <span class="card-media card-media-empty" role="img" aria-label="No image"></span>
                                {{/if}}
                                <span class="gallery-caption">{{title}}</span>
                            </a>
                        {{/foreach}}
                    </div>
                {{else}}
                    <p class="empty-note">No photos to display at the moment. Please check back soon.</p>
                {{/if}}
            {{/get}}

        </div>
    </section>
</article>
{{/post}}
