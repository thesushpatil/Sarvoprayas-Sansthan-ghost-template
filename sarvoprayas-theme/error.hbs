{{!< default}}
<section class="section section-bg-white">
    <div class="container-narrow" style="text-align: center; padding: 96px 32px;">
        <p class="section-eyebrow" style="justify-content: center; color: var(--c-amber);">Error {{statusCode}}</p>
        <h1 class="page-title" style="color: var(--c-ink); margin-bottom: 16px;">{{message}}</h1>
        <p class="page-lead" style="color: var(--c-muted);">
            Sorry, something went wrong or the page could not be found.
        </p>
        <p style="margin-top: 36px;">
            <a class="btn btn-primary" href="{{@site.url}}">Back to Home</a>
        </p>
    </div>
</section>
