{{!< default}}

{{#author}}
<header class="page-hero">
    <div class="container page-hero-inner">
        <p class="section-eyebrow">Author</p>
        <h1 class="page-title">{{name}}</h1>
        {{#if bio}}<p class="page-lead">{{bio}}</p>{{/if}}
    </div>
</header>
{{/author}}

<section class="section section-bg-white">
    <div class="container">
        {{#if posts}}
            <div class="cards-grid">
                {{#foreach posts}}
                    {{> "post-card"}}
                {{/foreach}}
            </div>
        {{else}}
            <p class="empty-note">No posts by this author yet.</p>
        {{/if}}
    </div>
</section>

{{> pagination}}
