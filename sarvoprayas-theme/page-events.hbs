{{!< default}}

{{#post}}
<article class="page-full">
    <header class="page-hero">
        <div class="container page-hero-inner">
            <p class="section-eyebrow">Events</p>
            <h1 class="page-title">{{title}}</h1>
            {{#if custom_excerpt}}<p class="page-lead">{{custom_excerpt}}</p>{{else}}<p class="page-lead empty-note">Description will be added soon.</p>{{/if}}
        </div>
    </header>

    <section class="events-section">
        <div class="container container-narrow">

            {{#if content}}
                <div style="padding-bottom: 32px;">{{content}}</div>
            {{/if}}

            {{!-- Pulls posts tagged "event", newest first. Use the post date as the event date. --}}
            {{#get "posts" filter="tag:event" limit="100" order="published_at desc" as |events|}}
                {{#if events}}
                    <ul class="events-list" data-paginate="6" aria-label="Upcoming events">
                        {{#foreach events}}
                            <li class="event-item">
                                <div class="event-date-block" aria-label="{{date format="DD MMM YYYY"}}">
                                    <span class="event-day">{{date format="DD"}}</span>
                                    <span class="event-month">{{date format="MMM"}}</span>
                                    <span class="event-year">{{date format="YYYY"}}</span>
                                </div>
                                <div class="event-body">
                                    <h3 class="event-title">
                                        <a href="{{url}}">{{title}}</a>
                                    </h3>
                                    <p class="event-excerpt">{{excerpt words="30"}}</p>
                                </div>
                            </li>
                        {{/foreach}}
                    </ul>
                {{else}}
                    <p class="empty-note">No upcoming events listed right now. Please check back soon.</p>
                {{/if}}
            {{/get}}

        </div>
    </section>
</article>
{{/post}}
