<footer class="site-footer" role="contentinfo">
    <div class="container">
        <div class="footer-inner">

            <div class="footer-col footer-about">
                <span class="footer-brand">{{@site.title}}</span>
                <p class="footer-desc">{{@site.description}}</p>
                <p class="footer-reg">
                    Reg. under Societies Registration Act, 1860 (No.&nbsp;{{@custom.reg_society_number}}).<br>
                    12A &amp; 80G &amp; FCRA registered. PAN: {{@custom.pan_number}}.
                </p>
            </div>

            <div class="footer-col footer-links">
                <h3 class="footer-heading">Explore</h3>
                <ul id="footer-explore">
                    {{!-- JS will populate this from secondary nav, stripping parent prefixes --}}
                </ul>
            </div>

            <div class="footer-col footer-links">
                <h3 class="footer-heading">Get Involved</h3>
                <ul id="footer-involved">
                    {{!-- JS will populate this with donate + contact links --}}
                </ul>
            </div>

            <div class="footer-col footer-contact">
                <h3 class="footer-heading">Reach Us</h3>
                <address>
                    {{@custom.office_address_1}}<br><br>
                    <a href="tel:{{@custom.contact_phone_1}}">{{@custom.contact_phone_1}}</a><br>
                    <a href="tel:{{@custom.contact_phone_2}}">{{@custom.contact_phone_2}}</a><br><br>
                    <a href="mailto:{{@custom.contact_email_1}}">{{@custom.contact_email_1}}</a>
                </address>
            </div>

        </div>
    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-inner">
            <span>&copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.</span>
            {{#if @custom.footer_tagline}}<span>{{@custom.footer_tagline}}</span>{{else}}<span class="empty-note">Tagline will be added soon.</span>{{/if}}
        </div>
    </div>
</footer>
