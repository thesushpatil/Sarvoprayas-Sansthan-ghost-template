<header class="site-header" id="site-header" role="banner">
    <div class="container header-inner">

        {{!-- Brand / Logo --}}
        <a class="site-brand" href="{{@site.url}}" aria-label="{{@site.title}}, Home">
            {{#if @site.logo}}
                <img class="site-logo" src="{{@site.logo}}" alt="{{@site.title}} logo" width="56" height="56">
            {{/if}}
            <span class="site-brand-text">
                <span class="site-brand-name">{{@site.title}}</span>
                <span class="site-brand-tagline">{{@custom.brand_tagline}}</span>
            </span>
        </a>

        {{!-- Mobile hamburger --}}
        <button class="nav-toggle" id="nav-toggle"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
            aria-controls="site-nav">
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
        </button>

        {{!-- Dynamic Navigation from Ghost Admin --}}
        <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
            <ul class="nav-menu" id="nav-menu" role="list">
                {{navigation}}
            </ul>

            {{!-- Secondary nav (hidden source for JS to build dropdowns from) --}}
            <ul id="nav-secondary-src" hidden>
                {{navigation type="secondary"}}
            </ul>

            {{!-- Right side: Donate button (moved here by JS from nav) + EN/Hindi toggle --}}
            <div class="header-actions">
                <span id="donate-btn-slot"></span>

                <div class="lang-toggle notranslate" translate="no" role="group" aria-label="Language selector">
                    <button type="button" class="lang-btn is-active notranslate" translate="no" data-lang="en" aria-pressed="true">EN</button>
                    <button type="button" class="lang-btn notranslate" translate="no" data-lang="hi" aria-pressed="false">हिं</button>
                </div>
            </div>
        </nav>

    </div>
</header>
