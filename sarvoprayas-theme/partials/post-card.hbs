<article class="card post-card">
    <a class="card-media-link" href="{{url}}">
        {{#if feature_image}}
            <img class="card-media"
                 src="{{img_url feature_image size="m"}}"
                 alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                 loading="lazy">
        {{else}}
            <span class="card-media placeholder" role="img" aria-label="Image placeholder">Image coming soon</span>
        {{/if}}
    </a>
    <div class="card-body">
        {{#if primary_tag}}
            <a class="card-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
        {{/if}}
        <h3 class="card-title">
            <a href="{{url}}">{{title}}</a>
        </h3>
        <p class="card-excerpt">{{excerpt words="20"}}</p>
        <time class="card-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
    </div>
</article>
